	<script>
		// Відкрити/закрити форму створення теми
		function toggleCreateForm() {
			var form = document.getElementById('topicForm');
			form.style.display = (form.style.display === 'block') ? 'none' : 'block';
		}

		// Функція додавання нової теми
		function publishTopic() {
			var author = document.getElementById('authorInput').value.trim();
			var title = document.getElementById('titleInput').value.trim();
			var text = document.getElementById('textInput').value.trim();
			var tagClass = document.getElementById('tagInput').value;
			var tagText = document.getElementById('tagInput').options[document.getElementById('tagInput').selectedIndex].text;

			if (!author || !title || !text) {
				alert('Будь ласка, заповніть усі поля перед публікацією!');
				return;
			}

			// Отримуємо перші літери для аватарки
			var avatarLetters = author.substring(0, 2).toUpperCase();

			// Створюємо новий елемент теми
			var newRow = document.createElement('div');
			newRow.className = 'news-feed-row';
			
			// Екрануємо текст, щоб лапки та переноси не ламали onclick в JS
			var safeText = text.replace(/'/g, "\\'").replace(/\n/g, "\\n");
			var safeTitle = title.replace(/'/g, "\\'");

			newRow.innerHTML = `
				<div class="feed-avatar">${avatarLetters}</div>
				<div class="feed-details">
					<div>
						<span class="badge ${tagClass}">${tagText}</span>
						<div class="feed-title" onclick="openTopic('${safeTitle}', '${author}', '${safeText}')">${title}</div>
					</div>
					<div class="feed-meta">Автор: <span style="color: var(--bf-glow); font-weight: bold;">${author}</span> · Щойно · Новинна стрічка</div>
				</div>
				<div class="feed-right">
					<div>Відповіді: <b>0</b></div>
					<div style="margin-top: 4px;">Перегляди: <b>1</b></div>
				</div>
			`;

			// Додаємо на самий початок стрічки новин
			var container = document.getElementById('newsFeedContainer');
			container.insertBefore(newRow, container.firstChild);

			// Очищаємо поля форми
			document.getElementById('titleInput').value = '';
			document.getElementById('textInput').value = '';
			toggleCreateForm();
		}

		// Функція красивого відкриття модального вікна з вмістом теми
		function openTopic(title, author, content) {
			document.getElementById('modalTitle').innerText = title;
			document.getElementById('modalAuthor').innerText = author;
			// Замінюємо символічні переноси рядків назад на реальні
			document.getElementById('modalBody').innerText = content.replace(/\\n/g, '\n');
			document.getElementById('topicModal').style.display = 'flex';
		}

		// Закриття модального вікна
		function closeModal() {
			document.getElementById('topicModal').style.display = 'none';
		}
	</script>
